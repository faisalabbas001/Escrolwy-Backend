{
  "name": "escrowly-backend",
  "version": "1.0.0",
  "description": "Escrowly Backend - Crypto Escrow, Wallet, and Ledger Platform",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "docker:clean": "docker-compose down -v",
    "auth:dev": "npm run start:dev -w auth",
    "auth:build": "npm run build -w auth",
    "auth:test": "npm run test -w auth",
    "auth:prisma:generate": "npx dotenv -e services/auth/.env -- prisma generate --schema=services/auth/prisma/schema.prisma",
    "auth:prisma:migrate": "npx dotenv -e services/auth/.env -- prisma migrate dev --schema=services/auth/prisma/schema.prisma",
    "auth:prisma:studio": "npx dotenv -e services/auth/.env -- prisma studio --schema=services/auth/prisma/schema.prisma",
    "admin:dev": "npm run start:dev -w admin",
    "admin:build": "npm run build -w admin",
    "admin:test": "npm run test -w admin",
    "admin:prisma:generate": "npx dotenv -e services/admin/.env -- prisma generate --schema=services/admin/prisma/schema.prisma",
    "admin:prisma:migrate": "npx dotenv -e services/admin/.env -- prisma migrate dev --schema=services/admin/prisma/schema.prisma",
    "admin:prisma:studio": "npx dotenv -e services/admin/.env -- prisma studio --schema=services/admin/prisma/schema.prisma",
    "inquiry:dev": "npm run start:dev -w inquiry",
    "inquiry:build": "npm run build -w inquiry",
    "inquiry:test": "npm run test -w inquiry",
    "inquiry:prisma:generate": "npx dotenv -e services/inquiry/.env -- prisma generate --schema=services/inquiry/prisma/schema.prisma",
    "inquiry:prisma:migrate": "npx dotenv -e services/inquiry/.env -- prisma migrate dev --schema=services/inquiry/prisma/schema.prisma",
    "inquiry:prisma:studio": "npx dotenv -e services/inquiry/.env -- prisma studio --schema=services/inquiry/prisma/schema.prisma",
    "notification:dev": "npm run start:dev -w notification",
    "notification:build": "npm run build -w notification",
    "notification:test": "npm run test -w notification",
    "notification:prisma:generate": "npx dotenv -e services/notification/.env -- prisma generate --schema=services/notification/prisma/schema.prisma",
    "notification:prisma:migrate": "npx dotenv -e services/notification/.env -- prisma migrate dev --schema=services/notification/prisma/schema.prisma",
    "notification:prisma:studio": "npx dotenv -e services/notification/.env -- prisma studio --schema=services/notification/prisma/schema.prisma",
    "bff:dev": "npm run start:dev -w bff",
    "bff:build": "npm run build -w bff",
    "listener:dev": "npm run start:dev -w listener-engine",
    "listener:build": "npm run build -w listener-engine",
    "listener:test": "npm run test -w listener-engine",
    "listener:prisma:generate": "npx dotenv -e services/listener-engine/.env -- prisma generate --schema=services/listener-engine/prisma/schema.prisma",
    "listener:prisma:migrate": "npx dotenv -e services/listener-engine/.env -- prisma migrate dev --schema=services/listener-engine/prisma/schema.prisma",
    "listener:prisma:studio": "npx dotenv -e services/listener-engine/.env -- prisma studio --schema=services/listener-engine/prisma/schema.prisma",
    "wallet:dev": "npm run start:dev -w wallet",
    "wallet:build": "npm run build -w wallet",
    "wallet:test": "npm run test -w wallet",
    "wallet:prisma:generate": "npx dotenv -e services/wallet/.env -- prisma generate --schema=services/wallet/prisma/schema.prisma",
    "wallet:prisma:migrate": "npx dotenv -e services/wallet/.env -- prisma migrate dev --schema=services/wallet/prisma/schema.prisma",
    "wallet:prisma:studio": "npx dotenv -e services/wallet/.env -- prisma studio --schema=services/wallet/prisma/schema.prisma",
    "test:bff": "node scripts/test-bff.js",
    "test:bff:complete": "node scripts/test-bff-complete.js",
    "test:auth:signup": "node scripts/test-auth-signup.js",
    "test:auth:login": "node scripts/test-auth-login.js",
    "test:wallet:events": "node scripts/test-wallet-events.js",
    "test:solana:deposit": "node scripts/test-solana-deposit.js",
    "test:solana:withdrawal": "node scripts/test-solana-withdrawal.js",
    "test:tron:withdrawal": "node scripts/test-tron-withdrawal.js"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.470.0",
    "@cspotcode/source-map-support": "^0.8.1",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.3.0",
    "pg": "^8.11.3",
    "prisma": "^6.19.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4"
  }
}