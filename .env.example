# ====================================
# Escrowly Backend - Environment Variables
# Copy to .env and fill in values for deployment
# ====================================

# JWT Secret (MUST be same across all services)
JWT_SECRET=your_secure_jwt_secret_here_min_32_chars

# AWS Credentials (for S3 image uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=your_s3_bucket_name

# Frontend URL (for CORS - optional, currently allowing all origins)
FRONTEND_URL=http://your-frontend-domain.com

