# ====================================
# Auth Service - Environment Variables
# ====================================

# Application
NODE_ENV=development
PORT=3001
SERVICE_NAME=auth-service

# Database (Single PostgreSQL instance, auth_db schema)
# Local: Use docker-compose PostgreSQL
# AWS: Use Aurora PostgreSQL endpoint (after infra deployment)
DATABASE_URL="postgresql://escrowly_dev:escrowly_dev_password@localhost:5432/escrowly?schema=auth_db"

# JWT Configuration
JWT_SECRET=dummy_jwt_secret_change_after_deployment
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Redis (Caching & Session)
# Local: docker-compose Redis
# AWS: ElastiCache endpoint
REDIS_URL=redis://:escrowly_redis_password@localhost:6379

# Kafka (Event Streaming)
# Local: Redpanda from docker-compose
# AWS: MSK endpoint
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=auth-service
KAFKA_GROUP_ID=auth-service-group

# AWS Services Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# AWS Secrets Manager
# Local Dev: Leave as "dummy" to use .env file
# Dev/Stage/Prod: Set to real ARN to use Secrets Manager
# Example: arn:aws:secretsmanager:us-east-1:123456789012:secret:dev-escrowly-app-secrets-ABC123
AWS_SECRETS_MANAGER_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:dev-escrowly-app-secrets-dummy

# AWS KMS (Encryption)
AWS_KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/dummy-key-id

# AWS S3 (Document Storage)
AWS_S3_BUCKET=dev-escrowly-files
AWS_S3_REGION=us-east-1

# Email (Mailhog for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@escrowly.local

# Logging
LOG_LEVEL=debug

