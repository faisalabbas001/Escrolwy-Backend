# Compliance Service Environment Variables

# Service Configuration
NODE_ENV=development
PORT=3003
SERVICE_NAME=compliance-service

# Database (PostgreSQL)
DATABASE_URL=postgresql://escrowly_dev:escrowly_dev_password@localhost:5433/escrowly?schema=compliance_db

# Persona KYC Configuration
PERSONA_API_KEY=persona_sandbox_xxxxxxxxxxxxxxxx
PERSONA_TEMPLATE_ID=itmpl_xxxxxxxxxxxxxxxx
PERSONA_WEBHOOK_SECRET=your_webhook_secret_here
PERSONA_ENVIRONMENT=sandbox

# Kafka Configuration
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:19092

# Redis (if needed)
REDIS_URL=redis://:escrowly_redis_password@localhost:6379
