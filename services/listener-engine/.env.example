# Environment
NODE_ENV=development
PORT=3003
SERVICE_NAME=listener-engine

# Chain to listen (one of: eth, bnb, poly, sol, trc)
CHAIN=eth

# Database
DATABASE_URL=postgresql://escrowly_dev:escrowly_dev_password@localhost:5433/escrowly?schema=listener_engine_db

# Redis
REDIS_URL=redis://:escrowly_redis_password@localhost:6379

# RPC URLs (Single URL - legacy format, still supported)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/sBUwi2hKRRmcGTTafh7fqRhE6rFI2baY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/sBUwi2hKRRmcGTTafh7fqRhE6rFI2baY
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/sBUwi2hKRRmcGTTafh7fqRhE6rFI2baY
# WARNING: BSC URL below appears to be Base mainnet, not BSC. Please verify.
BSC_RPC_URL=https://base-mainnet.infura.io/v3/4120f75b8bed44339e481eba3f3b29cf
# WARNING: Tron URL below appears to be Solana, not Tron. Please verify.
TRON_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/sBUwi2hKRRmcGTTafh7fqRhE6rFI2baY

# RPC URLs (Multiple URLs - comma-separated for failover)
# The listener will automatically switch to the next RPC if one fails
# Recommended: Add backup RPCs for redundancy
ETH_RPC_URLS=https://eth-mainnet.g.alchemy.com/v2/sBUwi2hKRRmcGTTafh7fqRhE6rFI2baY
POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/sBUwi2hKRRmcGTTafh7fqRhE6rFI2baY
SOLANA_RPC_URLS=https://solana-mainnet.g.alchemy.com/v2/sBUwi2hKRRmcGTTafh7fqRhE6rFI2baY
# WARNING: BSC URL below appears to be Base mainnet, not BSC. Please verify.
BSC_RPC_URLS=https://base-mainnet.infura.io/v3/4120f75b8bed44339e481eba3f3b29cf
# WARNING: Tron URL below appears to be Solana, not Tron. Please verify.
# Tron RPCs typically look like: https://api.trongrid.io or https://tron.blockpi.network/v1/rpc/public
TRON_RPC_URLS=https://solana-mainnet.g.alchemy.com/v2/sBUwi2hKRRmcGTTafh7fqRhE6rFI2baY

# Optional: AWS Secrets Manager (for production)
# AWS_SECRETS_MANAGER_ARN=arn:aws:secretsmanager:...
# AWS_REGION=us-east-1

