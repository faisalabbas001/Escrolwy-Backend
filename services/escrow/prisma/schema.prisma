datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
    schemas  = ["escrow_db"]
}

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

/// Represents a single escrow transaction with current state
model Escrow {
    id             String             @id @default(uuid())
    buyerId        String
    sellerId       String
    brokerId       String?
    amount         Decimal            @db.Decimal(18, 6)
    asset          String
    chain          String
    platformFee    Decimal            @db.Decimal(18, 6)
    state          String             @default("agreement")
    description    String?
    createdAt      DateTime           @default(now())
    updatedAt      DateTime           @updatedAt
    expiresAt      DateTime?
    completedAt    DateTime?
    disputedAt     DateTime?
    createdBy      String
    disputedBy     String?
    // Payment tracking fields
    buyerPaid      Boolean            @default(false)
    sellerPaid     Boolean            @default(false)
    buyerPaidAmount Decimal?          @db.Decimal(18, 6)
    sellerPaidAmount Decimal?          @db.Decimal(18, 6)
    fees           EscrowFees?
    feeSplit       EscrowFeeSplit?
    outboxEvents   EscrowOutbox[]
    reminders      EscrowReminder[]
    transitions    EscrowTransition[]

    @@index([buyerId])
    @@index([sellerId])
    @@index([state])
    @@index([createdAt])
    @@map("escrows")
    @@schema("escrow_db")
}

/// Immutable audit trail - records every state change
model EscrowTransition {
    id            String   @id @default(uuid())
    escrowId      String
    previousState String
    newState      String
    changedBy     String
    reason        String?
    metadata      Json?
    createdAt     DateTime @default(now())
    escrow        Escrow   @relation(fields: [escrowId], references: [id], onDelete: Cascade)

    @@index([escrowId])
    @@index([createdAt])
    @@map("escrow_transitions")
    @@schema("escrow_db")
}

/// Tracks platform fee per escrow
model EscrowFees {
    id            String   @id @default(uuid())
    escrowId      String   @unique
    feeAmount     Decimal  @db.Decimal(18, 6)
    feePercentage Decimal? @db.Decimal(5, 2)
    paidBy        String
    createdAt     DateTime @default(now())
    escrow        Escrow   @relation(fields: [escrowId], references: [id], onDelete: Cascade)

    @@index([escrowId])
    @@map("escrow_fees")
    @@schema("escrow_db")
}

/// Tracks fee split configuration per escrow
model EscrowFeeSplit {
    id            String   @id @default(uuid())
    escrowId      String   @unique
    feeAmount     Decimal  @db.Decimal(18, 6)
    buyerPays     Decimal  @db.Decimal(18, 6)  // Amount buyer pays
    sellerPays    Decimal  @db.Decimal(18, 6)   // Amount seller pays
    brokerPays    Decimal? @db.Decimal(18, 6)   // Optional broker share
    buyerPercent  Decimal? @db.Decimal(5, 2)    // Percentage (0-100)
    sellerPercent Decimal? @db.Decimal(5, 2)
    brokerPercent Decimal? @db.Decimal(5, 2)
    paidBy        String   // "buyer" | "seller" | "split" | "broker"
    createdAt     DateTime @default(now())
    escrow        Escrow   @relation(fields: [escrowId], references: [id], onDelete: Cascade)

    @@index([escrowId])
    @@map("escrow_fee_splits")
    @@schema("escrow_db")
}

/// Tracks deadlines and reminders for SLA management
model EscrowReminder {
    id          String    @id @default(uuid())
    escrowId    String
    type        String
    scheduledAt DateTime
    sentAt      DateTime?
    metadata    Json?
    createdAt   DateTime  @default(now())
    escrow      Escrow    @relation(fields: [escrowId], references: [id], onDelete: Cascade)

    @@index([escrowId])
    @@index([scheduledAt])
    @@map("escrow_reminders")
    @@schema("escrow_db")
}

/// Guarantees Kafka events are never lost - Transactional Outbox Pattern
/// Events are written here in same transaction as state changes,
/// then published to Kafka by the outbox processor.
model OutboxEvent {
    id           String    @id @default(uuid())
    topic        String // Kafka topic
    partitionKey String // Partition key (escrowId)
    payload      String    @db.Text // JSON-serialized event
    status       String    @default("pending") // pending | published | failed
    retryCount   Int       @default(0) // Number of publish attempts
    lastError    String?   @db.Text // Last error message
    createdAt    DateTime  @default(now())
    publishedAt  DateTime? // When published to Kafka
    nextRetryAt  DateTime? // For exponential backoff

    @@index([status])
    @@index([createdAt])
    @@index([nextRetryAt])
    @@index([topic])
    @@map("outbox_events")
    @@schema("escrow_db")
}

/// Legacy outbox - keeping for migration compatibility
model EscrowOutbox {
    id        String   @id @default(uuid())
    escrowId  String?
    eventType String
    eventKey  String   @unique
    payload   Json
    status    String   @default("pending")
    attempts  Int      @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    escrow    Escrow?  @relation(fields: [escrowId], references: [id])

    @@index([escrowId])
    @@index([eventType])
    @@index([status])
    @@index([createdAt])
    @@map("escrow_outbox")
    @@schema("escrow_db")
}
