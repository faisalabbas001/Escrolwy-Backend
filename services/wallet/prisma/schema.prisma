// Prisma schema for Wallet Service
// Uses wallet_db schema in shared PostgreSQL instance

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["wallet_db"]
}

// ====================================
// Wallet Service Models
// ====================================

/// Stores custodial wallets created per user on supported chains
model UserWallet {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  chain               String   @db.VarChar(10) // evm, sol, trc
  depositAddress      String   @map("deposit_address") @db.Text
  encryptedPrivateKey String   @map("encrypted_private_key") @db.Text
  publicKey           String?  @map("public_key") @db.Text
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([chain, depositAddress], name: "chain_deposit_address_unique")
  @@index([depositAddress], map: "idx_user_wallets_deposit_address")
  @@index([userId], map: "idx_user_wallets_user_id")
  @@map("user_wallets")
  @@schema("wallet_db")
}

/// Tracks detected on-chain deposits
model DepositTransaction {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  walletId       String   @map("wallet_id") @db.Uuid
  chain          String   @db.VarChar(10)
  asset          String   @db.VarChar(10)
  amount         Decimal  @db.Decimal(36, 18)
  txHash         String   @map("tx_hash") @db.Text
  blockNumber    BigInt   @map("block_number")
  depositAddress String   @map("deposit_address") @db.Text
  status         String   @default("pending") @db.VarChar(20) // pending, confirmed, processed
  detectedAt     DateTime @default(now()) @map("detected_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([chain, txHash], name: "chain_tx_hash_unique")
  @@index([depositAddress], map: "idx_deposit_tx_deposit_address")
  @@index([userId], map: "idx_deposit_tx_user_id")
  @@index([status], map: "idx_deposit_tx_status")
  @@index([walletId], map: "idx_deposit_tx_wallet_id")
  @@map("deposit_transactions")
  @@schema("wallet_db")
}

/// Tracks all on-chain withdrawal executions initiated by Ledger events
model PayoutRequest {
  id                 String    @id @default(uuid()) @db.Uuid
  eventId            String    @unique @map("event_id") @db.Text // Idempotency key from Kafka
  userId             String    @map("user_id") @db.Uuid
  chain              String    @db.VarChar(10)
  asset              String    @db.VarChar(10)
  amount             Decimal   @db.Decimal(36, 18)
  destinationAddress String    @map("destination_address") @db.Text
  status             String    @default("pending") @db.VarChar(20) // pending, fulfilled, failed
  txHash             String?   @map("tx_hash") @db.Text
  blockNumber        BigInt?   @map("block_number")
  gasUsed            Decimal?  @map("gas_used") @db.Decimal(36, 18)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([userId], map: "idx_payout_requests_user_id")
  @@index([status], map: "idx_payout_requests_status")
  @@map("payout_requests")
  @@schema("wallet_db")
}

/// Audit log for failed on-chain withdrawal attempts
model PayoutAttempt {
  id              String   @id @default(uuid()) @db.Uuid
  payoutRequestId String   @map("payout_request_id") @db.Uuid // Soft reference to payout_requests
  attemptNumber   Int      @map("attempt_number")
  errorMessage    String?  @map("error_message") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([payoutRequestId], map: "idx_payout_attempts_request_id")
  @@map("payout_attempts")
  @@schema("wallet_db")
}

/// Tracks processed Kafka events for idempotency
model ProcessedEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @unique @map("event_id") @db.Text
  eventType String   @map("event_type") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([eventId], map: "idx_processed_events_event_id")
  @@map("processed_events")
  @@schema("wallet_db")
}

/// Reliable Kafka event publishing using outbox pattern
model OutboxEvent {
  id           String    @id @default(uuid()) @db.Uuid
  topic        String    @db.Text
  partitionKey String    @map("partition_key") @db.Text
  payload      String    @db.Text
  status       String    @default("pending") @db.VarChar(20) // pending, processing, published, failed
  retryCount   Int       @default(0) @map("retry_count")
  lastError    String?   @map("last_error") @db.Text
  nextRetryAt  DateTime? @map("next_retry_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  publishedAt  DateTime? @map("published_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([status], map: "idx_outbox_events_status")
  @@index([createdAt], map: "idx_outbox_events_created_at")
  @@index([nextRetryAt], map: "idx_outbox_events_next_retry_at")
  @@map("outbox_events")
  @@schema("wallet_db")
}

/// Platform wallet keys and addresses (hot, funding, cold)
/// Private keys are KMS-encrypted and decrypted on-demand
model PlatformKey {
  id                  String   @id @default(uuid()) @db.Uuid
  chain               String   @db.VarChar(10) // evm, sol, trc
  walletType          String   @map("wallet_type") @db.VarChar(20) // hot, funding, cold
  publicAddress       String   @map("public_address") @db.Text
  encryptedPrivateKey String?  @map("encrypted_private_key") @db.Text // KMS-encrypted (nullable for cold)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([chain, walletType], name: "chain_wallet_type_unique")
  @@index([chain], map: "idx_platform_keys_chain")
  @@map("platform_keys")
  @@schema("wallet_db")
}

