# ====================================
# Wallet Service Environment Variables
# ====================================

# Service Configuration
NODE_ENV=development
PORT=3004
SERVICE_NAME=wallet-service

# Database (PostgreSQL with wallet_db schema)
DATABASE_URL=postgresql://escrowly_dev:escrowly_dev_password@localhost:5433/escrowly?schema=wallet_db

# Redis (for consuming raw events from listener-engine)
REDIS_URL=redis://:escrowly_redis_password@localhost:6379

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_ENABLED=true

# ====================================
# Blockchain RPC URLs
# ====================================

# EVM Chains
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Tron
TRON_RPC_URL=https://api.trongrid.io

# ====================================
# Hot Wallet Addresses
# Platform-controlled wallets for withdrawals and sweeps
# ====================================

EVM_HOT_WALLET=0x0000000000000000000000000000000000000000
SOL_HOT_WALLET=11111111111111111111111111111111
TRC_HOT_WALLET=T0000000000000000000000000000000

# ====================================
# Funding Wallet Private Keys
# WARNING: Store securely in production (use Secrets Manager)
# ====================================

# EVM funding wallet private key (hex without 0x prefix)
EVM_FUNDING_WALLET_KEY=

# Solana funding wallet private key (base64 encoded)
SOL_FUNDING_WALLET_KEY=

# Tron funding wallet private key (hex)
TRC_FUNDING_WALLET_KEY=

# ====================================
# Encryption Configuration
# ====================================

# Encryption mode: 'local' for development, 'kms' for production
ENCRYPTION_MODE=local

# Local encryption key (32 bytes hex) - only used when ENCRYPTION_MODE=local
# Generate with: openssl rand -hex 32
WALLET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ====================================
# AWS KMS Configuration (Production)
# Required when ENCRYPTION_MODE=kms
# ====================================

# AWS region for KMS and Secrets Manager
AWS_REGION=us-east-1

# KMS Customer Master Key ARN for envelope encryption
# Create via AWS Console: KMS > Customer managed keys > Create key
AWS_KMS_CMK_ARN=arn:aws:kms:us-east-1:123456789012:key/your-key-id

# Secrets Manager secret name containing platform wallet keys
# Keys stored as JSON: {"EVM_HOT_WALLET_KEY": "...", "EVM_FUNDING_WALLET_KEY": "...", ...}
AWS_SECRETS_MANAGER_SECRET=escrowly-platform-wallet-keys

# ====================================
# Funding Thresholds
# Minimum native token balance before auto-funding
# ====================================

# EVM (ETH/BNB/MATIC)
EVM_FUNDING_THRESHOLD=0.1
EVM_FUNDING_AMOUNT=0.5

# Solana (SOL)
SOL_FUNDING_THRESHOLD=1
SOL_FUNDING_AMOUNT=5

# Tron (TRX)
TRC_FUNDING_THRESHOLD=100
TRC_FUNDING_AMOUNT=500

# ====================================
# Cron Job Schedules
# ====================================

# Withdrawal retry cron (default: every 30 seconds)
WITHDRAWAL_RETRY_CRON=*/30 * * * * *

# Deposit sweep cron (default: every 5 minutes)
DEPOSIT_SWEEP_CRON=0 */5 * * * *

# ====================================
# Logging
# ====================================

LOG_LEVEL=debug

