# ====================================
# Reporting Service - Environment Variables
# ====================================

# Application
NODE_ENV=development
PORT=3007
SERVICE_NAME=reporting-service

# Database (Single PostgreSQL instance, reporting_db schema)
# Local: Use docker-compose PostgreSQL
# AWS: Use Aurora PostgreSQL endpoint (after infra deployment)
DATABASE_URL="postgresql://escrowly_dev:escrowly_dev_password@localhost:5432/escrowly?schema=reporting_db"

# Service-to-Service Authentication
# Token used for internal service-to-service API calls
SERVICE_TO_SERVICE_TOKEN=dummy_service_token_change_in_production

# Kafka (Event Streaming)
# Local: Redpanda from docker-compose
# AWS: MSK endpoint
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=reporting-service
KAFKA_GROUP_ID=reporting-service-group

# AWS Services Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# AWS Secrets Manager
# Local Dev: Leave as "dummy" to use .env file
# Dev/Stage/Prod: Set to real ARN to use Secrets Manager
# Example: arn:aws:secretsmanager:us-east-1:123456789012:secret:dev-escrowly-app-secrets-ABC123
AWS_SECRETS_MANAGER_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:dev-escrowly-app-secrets-dummy

# AWS S3 (Report Storage)
AWS_S3_BUCKET=dev-escrowly-reports
AWS_S3_REGION=us-east-1

# Logging
LOG_LEVEL=debug
