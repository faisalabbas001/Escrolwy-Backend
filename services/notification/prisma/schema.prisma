// Prisma schema for Notification Service
// Uses notification_db schema in shared PostgreSQL instance

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["notification_db"]
}

// ====================================
// Enums
// ====================================

enum NotificationStatus {
  sent
  failed
  skipped

  @@schema("notification_db")
}

enum OutboxEventStatus {
  pending
  published
  failed

  @@schema("notification_db")
}

// ====================================
// Notification Service Models
// ====================================

// User notification preferences
// Stores per-user email notification settings
model UserNotificationSettings {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Text
  emailInquiryMessages  Boolean  @default(true) @map("email_inquiry_messages")
  emailInquiryResolved  Boolean  @default(true) @map("email_inquiry_resolved")
  emailEscrowCreated    Boolean  @default(true) @map("email_escrow_created")
  emailEscrowCompleted  Boolean  @default(true) @map("email_escrow_completed")
  emailEscrowDisputed   Boolean  @default(true) @map("email_escrow_disputed")
  emailWalletDeposit    Boolean  @default(true) @map("email_wallet_deposit")
  emailWalletWithdrawal Boolean  @default(true) @map("email_wallet_withdrawal")
  emailPasswordChanged  Boolean  @default(true) @map("email_password_changed")
  emailEmailUpdated     Boolean  @default(true) @map("email_email_updated")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([userId])
  @@map("user_notification_settings")
  @@schema("notification_db")
}

// Notification delivery logs (append-only)
// Records all email delivery attempts
model NotificationLog {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Text
  eventType     String    @map("event_type") @db.Text
  eventKey      String?   @map("event_key") @db.Text
  templateId    String    @map("template_id") @db.Text
  recipientEmail String   @map("recipient_email") @db.Text
  subject       String    @db.Text
  status        NotificationStatus
  errorMessage  String?   @map("error_message") @db.Text
  resendId      String?   @map("resend_id") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@index([eventKey])
  @@index([userId, status, createdAt(sort: Desc)])
  @@map("notification_logs")
  @@schema("notification_db")
}

// Processed events (idempotency)
// Prevents duplicate processing of Kafka events
model ProcessedEvent {
  id          String   @id @default(uuid()) @db.Uuid
  eventKey    String   @unique @map("event_key") @db.Text
  eventType   String   @map("event_type") @db.Text
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz

  @@index([eventKey])
  @@index([eventType])
  @@map("processed_events")
  @@schema("notification_db")
}

// Notification outbox (for future event publishing if needed)
// Follows transactional outbox pattern
model OutboxEvent {
  id           String    @id @default(uuid()) @db.Uuid
  topic        String    @db.Text
  partitionKey String    @map("partition_key") @db.Text
  payload      String    @db.Text
  status       OutboxEventStatus @default(pending)
  retryCount   Int       @default(0) @map("retry_count")
  lastError    String?   @map("last_error") @db.Text
  nextRetryAt  DateTime? @map("next_retry_at") @db.Timestamptz
  publishedAt  DateTime? @map("published_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([status])
  @@index([createdAt])
  @@index([nextRetryAt])
  @@index([topic])
  @@map("outbox_events")
  @@schema("notification_db")
}

// Email template metadata stored in database
// Templates must exist in Resend Dashboard with matching templateId
// This table stores metadata, validation rules, and variable definitions
model EmailTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  templateId String   @unique @map("template_id") @db.Text // Must match Resend template ID
  name       String   @map("name") @db.Text
  description String? @map("description") @db.Text
  subject    String   @map("subject") @db.Text // Handlebars template
  html       String   @map("html") @db.Text // Handlebars template
  variables  String?  @map("variables") @db.Text // JSON array of required variables
  version    String   @default("v1") @map("version") @db.Text
  isActive   Boolean  @default(true) @map("is_active")
  createdBy  String?  @map("created_by") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([templateId])
  @@index([isActive])
  @@map("email_templates")
  @@schema("notification_db")
}

