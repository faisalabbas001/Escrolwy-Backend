# ========================================
# Escrowly Inquiry Service - Environment Variables
# ========================================

# Server Configuration
PORT=3003
SERVICE_NAME=inquiry-service
NODE_ENV=development

# Database Configuration
# Option 1: Direct environment variables (development)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=inquiry_db

# Option 2: AWS Secrets Manager (production)
# - Set AWS_REGION and AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# - Credentials are loaded via SecretsService from @escrowly/shared-config
# AWS_REGION=us-east-1

# Database Connection String (or let PrismaModule construct it)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inquiry_db?schema=inquiry_db
#kafka configueratoin

KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=inquiry-service
KAFKA_GROUP_ID=inquiry-consumer-group
KAFKA_BROKERS=localhost:9092

